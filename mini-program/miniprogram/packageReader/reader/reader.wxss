.page-reader {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  background-color: var(--color-bg);
}

.page-reader--unavailable,
.page-reader--placeholder {
  align-items: center;
  justify-content: center;
}

.page-reader__unavailable-text {
  color: var(--color-text-secondary);
  font-size: var(--font-size-lg);
}

.page-reader__vertical-swiper {
  height: 100vh;
}

.page-reader__panel-swiper {
  flex: 1;
  min-height: 0;
}

.page-reader__panel-scroll {
  height: 100%;
  padding: var(--spacing-md);
  box-sizing: border-box;
}

.page-reader__panel-image {
  width: 100%;
  border-radius: var(--radius-md);
}

.page-reader__details {
  height: 44vh;
  padding: var(--spacing-md) var(--spacing-lg) calc(var(--spacing-lg) + env(safe-area-inset-bottom));
  background-color: var(--color-bg-card);
  border-top: 1rpx solid var(--color-border);
}

.page-reader__series {
  color: var(--color-primary);
  font-size: var(--font-size-sm);
}

.page-reader__title,
.page-reader__summary {
  display: block;
}

.page-reader__title {
  margin-top: var(--spacing-xs);
  color: var(--color-text);
  font-size: var(--font-size-xl);
  font-weight: bold;
}

.page-reader__summary {
  margin-top: var(--spacing-xs);
  color: var(--color-text-secondary);
  font-size: var(--font-size-sm);
}

.page-reader__counts {
  display: flex;
  gap: var(--spacing-md);
  margin-top: var(--spacing-md);
  color: var(--color-text-secondary);
  font-size: var(--font-size-xs);
}

.page-reader__actions {
  display: flex;
  gap: var(--spacing-sm);
  margin-top: var(--spacing-md);
}

.page-reader__action,
.page-reader__comment-submit,
.page-reader__load-more {
  margin: 0;
  color: var(--color-primary);
  font-size: var(--font-size-sm);
  background-color: var(--color-primary-light);
}

.page-reader__action {
  flex: 1;
}

.page-reader__action--active,
.page-reader__comment-submit {
  color: var(--color-bg-card);
  background-color: var(--color-primary);
}

.page-reader__comments {
  margin-top: var(--spacing-lg);
  padding-top: var(--spacing-md);
  border-top: 1rpx solid var(--color-border);
}

.page-reader__comments-title {
  font-size: var(--font-size-lg);
  font-weight: bold;
}

.page-reader__comment-input {
  width: 100%;
  min-height: 128rpx;
  margin-top: var(--spacing-sm);
  padding: var(--spacing-sm);
  border: 1rpx solid var(--color-border);
  border-radius: var(--radius-sm);
  box-sizing: border-box;
  font-size: var(--font-size-sm);
}

.page-reader__comment-submit {
  margin-top: var(--spacing-sm);
}

.page-reader__comment {
  margin-top: var(--spacing-md);
  padding-top: var(--spacing-md);
  border-top: 1rpx solid var(--color-border);
}

.page-reader__comment-author,
.page-reader__comment-actions {
  display: flex;
  align-items: center;
  gap: var(--spacing-sm);
}

.page-reader__comment-author {
  color: var(--color-text-secondary);
  font-size: var(--font-size-sm);
}

.page-reader__comment-avatar {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
}

.page-reader__comment-content {
  display: block;
  margin-top: var(--spacing-sm);
  font-size: var(--font-size-base);
  white-space: pre-wrap;
}

.page-reader__comment-actions {
  margin-top: var(--spacing-sm);
}

.page-reader__comment-action {
  color: var(--color-text-secondary);
  font-size: var(--font-size-xs);
}

.page-reader__comment-action--active {
  color: var(--color-primary);
}

.page-reader__comment-action--danger {
  color: var(--color-danger);
}

.page-reader__load-more {
  margin-top: var(--spacing-md);
}

.page-reader__comment-empty {
  display: block;
  margin-top: var(--spacing-md);
  color: var(--color-text-secondary);
  font-size: var(--font-size-sm);
  text-align: center;
}
