<view class="counter-card">
  <text class="label">组件内计数</text>
  <view class="counter-display">
    <text class="count">{{count}}</text>
    <text class="parity">{{isEven ? '偶数' : '奇数'}}</text>
  </view>
  <view class="actions">
    <button class="btn" bind:tap="decrement">-1</button>
    <button class="btn" bind:tap="increment">+1</button>
  </view>
</view>
