<view class="page-home">
  <view class="page-home__header">
    <view>
      <text class="page-home__title">漫画条</text>
      <text class="page-home__subtitle">最新发布的四格故事</text>
    </view>
    <view class="page-home__header-actions">
      <view class="page-home__header-link" bind:tap="handleOpenDiscover">发现</view>
      <view class="page-home__header-link" bind:tap="handleOpenProfile">我的</view>
    </view>
  </view>

  <view wx:if="{{episodes.length}}" class="page-home__episode-list">
    <episode-card wx:for="{{episodes}}" wx:key="id" episode="{{item}}" bind:open="handleOpenEpisode" />
  </view>

  <view wx:if="{{hasLoaded && !episodes.length}}" class="page-home__empty-state">暂时没有可阅读的漫画</view>
  <view wx:if="{{isLoadingMore}}" class="page-home__loading-more">正在加载更多内容</view>
</view>
