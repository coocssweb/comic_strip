<view class="page-profile">
  <view wx:if="{{!isLoggedIn}}" class="page-profile__login-card">
    <text class="page-profile__login-title">登录后管理你的互动</text>
    <text class="page-profile__login-description">收藏、单话点赞和评论会保存在这里。</text>
    <button class="page-profile__login-button" bind:tap="handleLogin">微信登录</button>
  </view>

  <block wx:else>
    <view class="page-profile__reader-card">
      <image wx:if="{{reader.avatarUrl}}" class="page-profile__avatar" src="{{reader.avatarUrl}}" mode="aspectFill" />
      <view wx:else class="page-profile__avatar page-profile__avatar--placeholder">我</view>
      <text class="page-profile__reader-name">{{reader.displayName}}</text>
    </view>

    <view class="page-profile__sections">
      <view class="page-profile__section {{activeSection === 'favorites' ? 'page-profile__section--active' : ''}}" data-section="favorites" bind:tap="handleSelectSection">我的收藏</view>
      <view class="page-profile__section {{activeSection === 'likes' ? 'page-profile__section--active' : ''}}" data-section="likes" bind:tap="handleSelectSection">我的点赞</view>
      <view class="page-profile__section {{activeSection === 'comments' ? 'page-profile__section--active' : ''}}" data-section="comments" bind:tap="handleSelectSection">我的评论</view>
    </view>

    <view wx:if="{{activeSection !== 'comments' && items.length}}" class="page-profile__episode-list">
      <episode-card wx:for="{{items}}" wx:key="id" episode="{{item}}" bind:open="handleOpenEpisode" />
    </view>

    <view wx:if="{{activeSection === 'comments' && items.length}}" class="page-profile__comment-list">
      <view wx:for="{{items}}" wx:key="id" class="page-profile__comment" data-episode-id="{{item.episodeId}}" bind:tap="handleOpenCommentEpisode">
        <view class="page-profile__comment-author">
          <image wx:if="{{item.authorAvatarUrl}}" class="page-profile__comment-avatar" src="{{item.authorAvatarUrl}}" mode="aspectFill" />
          <text>{{item.authorName}}</text>
        </view>
        <text class="page-profile__comment-content">{{item.content}}</text>
        <text class="page-profile__comment-meta">点赞 {{item.likeCount}}</text>
      </view>
    </view>

    <view wx:if="{{hasLoaded && !items.length}}" class="page-profile__empty-state">暂时没有互动记录</view>
    <view wx:if="{{isLoadingMore}}" class="page-profile__loading-more">正在加载更多内容</view>
  </block>
</view>
