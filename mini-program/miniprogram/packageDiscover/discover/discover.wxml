<view class="page-discover">
  <view wx:if="{{ranking.length}}" class="page-discover__section">
    <view class="page-discover__section-heading">
      <text class="page-discover__section-title">月度热度榜</text>
      <text class="page-discover__section-note">{{month}}</text>
    </view>
    <view class="page-discover__ranking-list">
      <view wx:for="{{ranking}}" wx:key="seriesId" class="page-discover__ranking-row" data-series-id="{{item.seriesId}}" bind:tap="handleOpenSeries">
        <text class="page-discover__rank">{{item.rank}}</text>
        <view class="page-discover__ranking-series">
          <text class="page-discover__ranking-name">{{item.seriesName}}</text>
          <text class="page-discover__ranking-author">{{item.authorByline}}</text>
        </view>
        <text class="page-discover__heat">热度 {{item.heat}}</text>
      </view>
    </view>
  </view>

  <view wx:if="{{topics.length}}" class="page-discover__section">
    <text class="page-discover__section-title">运营专题</text>
    <view class="page-discover__topic-list">
      <view wx:for="{{topics}}" wx:key="id" class="page-discover__topic-card" data-topic-id="{{item.id}}" bind:tap="handleOpenTopic">
        <image class="page-discover__topic-cover" src="{{item.coverImageUrl}}" mode="aspectFill" />
        <view class="page-discover__topic-content">
          <text class="page-discover__topic-title">{{item.title}}</text>
          <text wx:if="{{item.summary}}" class="page-discover__topic-summary">{{item.summary}}</text>
        </view>
      </view>
    </view>
  </view>

  <view wx:if="{{series.length}}" class="page-discover__section">
    <text class="page-discover__section-title">漫画系列</text>
    <view class="page-discover__series-list">
      <view wx:for="{{series}}" wx:key="id" class="page-discover__series-card" data-series-id="{{item.id}}" bind:tap="handleOpenSeries">
        <image class="page-discover__series-cover" src="{{item.thumbnailUrl}}" mode="aspectFill" />
        <view class="page-discover__series-content">
          <text class="page-discover__series-name">{{item.name}}</text>
          <text class="page-discover__series-author">{{item.authorByline}}</text>
        </view>
      </view>
    </view>
  </view>

  <view wx:if="{{hasLoaded && !hasContent}}" class="page-discover__empty-state">暂时没有可发现的内容</view>
  <view wx:if="{{isLoadingMore}}" class="page-discover__loading-more">正在加载更多内容</view>
</view>
