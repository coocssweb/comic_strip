.page-series {
  padding: var(--spacing-lg);
}

.page-series--unavailable,
.page-series__empty-state,
.page-series__loading-more {
  padding: var(--spacing-xl) var(--spacing-lg);
  color: var(--color-text-secondary);
  font-size: var(--font-size-base);
  text-align: center;
}

.page-series__header {
  display: flex;
  gap: var(--spacing-md);
  margin-bottom: var(--spacing-xl);
}

.page-series__cover {
  flex: 0 0 200rpx;
  width: 200rpx;
  height: 200rpx;
  border-radius: var(--radius-md);
}

.page-series__details {
  display: flex;
  flex: 1;
  flex-direction: column;
  min-width: 0;
}

.page-series__name {
  color: var(--color-text);
  font-size: var(--font-size-xl);
  font-weight: bold;
}

.page-series__author,
.page-series__summary {
  margin-top: var(--spacing-xs);
  color: var(--color-text-secondary);
  font-size: var(--font-size-sm);
}

.page-series__episode-list {
  display: flex;
  flex-direction: column;
  gap: var(--spacing-md);
}
