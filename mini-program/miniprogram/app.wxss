/* ==============================
   设计 token
   ============================== */

/* 颜色 */
page {
  --color-primary: #1a73e8;
  --color-primary-light: #e8f0fe;
  --color-text: #333333;
  --color-text-secondary: #888888;
  --color-bg: #f5f5f5;
  --color-bg-card: #ffffff;
  --color-border: #e8e8e8;
  --color-danger: #e53935;
  --color-success: #43a047;
}

/* 字号 */
page {
  --font-size-xs: 22rpx;
  --font-size-sm: 24rpx;
  --font-size-base: 28rpx;
  --font-size-lg: 32rpx;
  --font-size-xl: 36rpx;
  --font-size-xxl: 48rpx;
}

/* 间距 */
page {
  --spacing-xs: 8rpx;
  --spacing-sm: 16rpx;
  --spacing-md: 24rpx;
  --spacing-lg: 32rpx;
  --spacing-xl: 48rpx;
}

/* 圆角 */
page {
  --radius-sm: 8rpx;
  --radius-md: 12rpx;
  --radius-lg: 16rpx;
}

/* ==============================
   全局样式 reset
   ============================== */

page {
  font-size: var(--font-size-base);
  color: var(--color-text);
  background-color: var(--color-bg);
  box-sizing: border-box;
}

view, text {
  box-sizing: border-box;
}
