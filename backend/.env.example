# 运行环境（development / production / test）
NODE_ENV=test

# 服务端口
PORT=4001

# MongoDB 连接串
MONGODB_URI=mongodb://root:bestwish_123456@110.42.210.230:40123/comic-strip-dev?authSource=admin

# Admin JWT 签名密钥（生产环境使用随机生成的强密钥）
ADMIN_JWT_SECRET=change-me-to-a-random-secret-at-least-32-chars

# 安全 HMAC 密钥（生产环境使用随机生成的强密钥）
SECURITY_HMAC_SECRET=change-me-to-another-random-secret-at-least-32-chars

# Admin Web 前端地址（CORS 来源）
ADMIN_WEB_ORIGIN=http://localhost:4000

# 日志级别（fatal / error / warn / info / debug / trace）
LOG_LEVEL=debug

# COS (Tencent Cloud Object Storage) 配置
COS_SECRET_ID=your-cos-secret-id
COS_SECRET_KEY=your-cos-secret-key
COS_BUCKET=your-bucket-name-1234567890
COS_REGION=ap-guangzhou
# COS_CDN_DOMAIN=https://cdn.example.com
