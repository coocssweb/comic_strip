NODE_ENV=development
PORT=3000
MONGODB_URI=mongodb://127.0.0.1:27017/koa_mongodb_starter
MONGODB_RETRY_TIMES=3
MONGODB_RETRY_INTERVAL_MS=2000
WECHAT_APP_ID=your-wechat-app-id
WECHAT_APP_SECRET=your-wechat-app-secret
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=replace-with-a-bcrypt-hash
SESSION_SECRET=replace-with-a-long-random-secret
SESSION_EXPIRES_SECONDS=604800
COS_BUCKET=your-bucket-1234567890
COS_REGION=ap-shanghai
COS_PUBLIC_BASE_URL=https://your-bucket-1234567890.cos.ap-shanghai.myqcloud.com/
COS_UPLOAD_EXPIRES_SECONDS=300
COS_ACCESS_KEY_ID=your-cos-access-key-id
COS_SECRET_ACCESS_KEY=your-cos-secret-access-key
